# Copy this file to .env (do not commit .env).

# Required only for AI Coach responses via OpenAI (optional — fallback works offline).
OPENAI_API_KEY=

# Optional — override default chat model used by rag_engine.py
# PAWPAL_AI_MODEL=gpt-4o-mini

# Optional — override OpenAI API root (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional — sampling temperature (default 0.2 in rag_engine)
# PAWPAL_AI_TEMPERATURE=0.2
